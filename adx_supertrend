    if pe_t2_hit
        label.new(bar_index, pe_h_adj,
             "PE T2 HIT\nPrem:" + str.tostring(pe_h, "#.0"),
             style=label.style_label_down, color=color.new(color.orange, 0),
             textcolor=color.black, size=size.small)

    if pe_sl_hit
        label.new(bar_index, pe_c_adj,
             "PE SL HIT\nPrem:" + str.tostring(pe_c, "#.0") + " SL:" + str.tostring(pe_exit_sl_prem, "#.0"),
             style=label.style_label_down, color=color.new(color.maroon, 0),
             textcolor=color.white, size=size.small)

    if pe_time_exit
        label.new(bar_index, pe_c_adj,
             "PE TIME EXIT\nPrem:" + str.tostring(pe_c, "#.0") + " Entry:" + str.tostring(pe_exit_entry_prem, "#.0"),
             style=label.style_label_down, color=color.new(color.gray, 0),
             textcolor=color.white, size=size.small)

    if straddle_sl_hit
        label.new(bar_index, straddle_close,
             "STRADDLE SL\nVal:" + str.tostring(straddle_close, "#.0") + " | P&L:" + str.tostring(straddle_pnl_pct, "#.0") + "%",
             style=label.style_label_down, color=col_straddle_sl,
             textcolor=color.white, size=size.small)

    if show_os and os_ce_entry_trigger
        label.new(bar_index, ce_c,
             "SELL CE\nPrem:" + str.tostring(os_ce_entry_snap, "#.0") +
             "\nTgt:" + str.tostring(os_ce_target_snap, "#.0") +
             "\nSL(CE HR):" + str.tostring(os_ce_sl_snap, "#.0") +
             "\nADJ at TV1:" + str.tostring(os_ce_tv1_snap, "#.0"),
             style=label.style_label_down, color=col_os_ce,
             textcolor=color.white, size=size.small)

    if show_os and os_ce_exit
        label.new(bar_index, ce_c,
             "CE SHORT EXIT (" + os_ce_exit_reason + ")\nPrem:" + str.tostring(ce_c, "#.0") + " Entry:" + str.tostring(os_ce_entry_snap, "#.0"),
             style=label.style_label_up, color=os_ce_target_hit ? color.new(color.lime, 0) : os_ce_sl_hit ? color.new(color.red, 0) : color.new(color.gray, 0),
             textcolor=color.black, size=size.small)

    if show_os and os_pe_entry_trigger
        label.new(bar_index, pe_c_adj,
             "SELL PE\nPrem:" + str.tostring(os_pe_entry_snap, "#.0") +
             "\nTgt:" + str.tostring(os_pe_target_snap, "#.0") +
             "\nSL(PE HR):" + str.tostring(os_pe_sl_snap, "#.0") +
             "\nADJ at TV1:" + str.tostring(os_pe_tv1_snap, "#.0"),
