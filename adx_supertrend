// ═══════════════════════════════════════════════════════════
// 5. HELPERS
// ═══════════════════════════════════════════════════════════
f_ls(s) =>
    s == "Dotted" ? line.style_dotted : s == "Dashed" ? line.style_dashed : line.style_solid

// Use the option close as the signal price. Rounding to arbitrary ₹10 levels
// creates fills that may never have been tradable.

// All scheduling is based on the bar close in the exchange timezone. A
// "reached" check works on any intraday timeframe.
f_close_at_or_after(h, m) =>
    hour(time_close, "Asia/Kolkata") > h or (hour(time_close, "Asia/Kolkata") == h and minute(time_close, "Asia/Kolkata") >= m)

// ── BUY entry allowed only when the bar CLOSES at/after 09:30 ──
// Uses bar CLOSE time, so it works on any timeframe:
//   15m chart: first candle (9:15-9:30) closes 9:30 -> can trigger immediately
//   5m chart : 9:25-9:30 candle closes 9:30 -> first eligible trigger
buy_time_ok = f_close_at_or_after(9, 30)

// ═══════════════════════════════════════════════════════════
// 6. DATA REQUEST
// ═══════════════════════════════════════════════════════════
[ce_o, ce_h, ce_l, ce_c] = request.security(ce_sym, timeframe.period, [open, high, low, close])
[pe_o, pe_h, pe_l, pe_c] = request.security(pe_sym, timeframe.period, [open, high, low, close])

[ce_d_h, ce_d_l, ce_d_c] = request.security(ce_sym, "D", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)
[pe_d_h, pe_d_l, pe_d_c] = request.security(pe_sym, "D", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)

ce_vol = request.security(ce_sym, timeframe.period, volume)
pe_vol = request.security(pe_sym, timeframe.period, volume)

// ═══════════════════════════════════════════════════════════
// 7. PE ADJUSTED FOR GAP
// ═══════════════════════════════════════════════════════════
pe_o_adj = pe_o - gap_offset
pe_h_adj = pe_h - gap_offset
pe_l_adj = pe_l - gap_offset
pe_c_adj = pe_c - gap_offset

// ═══════════════════════════════════════════════════════════
// 8. SESSION TRACKING
// ═══════════════════════════════════════════════════════════
is_new_session = ta.change(time("D")) != 0

var int   session_start_bar  = na
var int   session_start_time = na
var float ce_open_high       = na
var float ce_open_low        = na
var float ce_open_close      = na
var float ce_open_open       = na
var float pe_open_high       = na
var float pe_open_low        = na
var float pe_open_close      = na
var float pe_open_open       = na
var float fib_low            = na
var float fib_high           = na

if is_new_session
    session_start_bar  := bar_index
    session_start_time := time
    ce_open_high      := ce_h
    ce_open_low       := ce_l
    ce_open_close     := ce_c
    ce_open_open      := ce_o
    pe_open_high      := pe_h
    pe_open_low       := pe_l
    pe_open_close     := pe_c
    pe_open_open      := pe_o
    fib_low           := math.min(ce_l, pe_l)
    fib_high          := math.max(ce_h, pe_h)

ce_oc_range = ce_open_high - ce_open_low
ce_oc_mid   = ce_open_low + ce_oc_range * 0.5
ce_t1_val   = ce_open_low + ce_oc_range * (pct_ce_t1 / 100.0)
ce_t2_val   = ce_open_low + ce_oc_range * (pct_ce_t2 / 100.0)

pe_oc_range = pe_open_high - pe_open_low
pe_oc_mid   = pe_open_low + pe_oc_range * 0.5
pe_t1_val   = pe_open_low + pe_oc_range * (pct_pe_t1 / 100.0)
pe_t2_val   = pe_open_low + pe_oc_range * (pct_pe_t2 / 100.0)

fib_range = (not na(fib_high) and not na(fib_low)) ? fib_high - fib_low : 0.0
fib_poc   = (not na(fib_low) and fib_range > 0) ? fib_low + fib_range * 0.5 : na

// ═══════════════════════════════════════════════════════════
// 8A. HALF RANGE
// ═══════════════════════════════════════════════════════════
half_range = fib_range > 0 ? fib_range / 2.0 : na

var float session_half_range = na
if is_new_session
    float _fh = math.max(ce_h, pe_h)
    float _fl = math.min(ce_l, pe_l)
    session_half_range := (_fh - _fl) / 2.0

