var array<int>   hist_start_bar  = array.new<int>()
var array<float> hist_poc        = array.new<float>()
var array<float> hist_hr_ce      = array.new<float>()
var array<float> hist_hr_pe      = array.new<float>()
var array<float> hist_tce1       = array.new<float>()
var array<float> hist_tce2       = array.new<float>()
var array<float> hist_tce3       = array.new<float>()
var array<float> hist_tce4       = array.new<float>()
var array<float> hist_tce5       = array.new<float>()
var array<float> hist_tpe1       = array.new<float>()
var array<float> hist_tpe2       = array.new<float>()
var array<float> hist_tpe3       = array.new<float>()
var array<float> hist_tpe4       = array.new<float>()
var array<float> hist_tpe5       = array.new<float>()
var array<int>   hist_end_bar    = array.new<int>()

if is_new_session
    if not na(fib_poc) and not na(session_start_bar)
        prev_fib_poc := fib_poc
        if array.size(hist_end_bar) > 0
            array.set(hist_end_bar, array.size(hist_end_bar) - 1, bar_index - 1)
        array.push(hist_start_bar, session_start_bar)
        array.push(hist_end_bar,   bar_index - 1)
        array.push(hist_poc,       fib_poc)
        array.push(hist_hr_ce,     hr_upper_val)
        array.push(hist_hr_pe,     hr_lower_val)
        array.push(hist_tce1,      tval_ce1)
        array.push(hist_tce2,      tval_ce2)
        array.push(hist_tce3,      tval_ce3)
        array.push(hist_tce4,      tval_ce4)
        array.push(hist_tce5,      tval_ce5)
        array.push(hist_tpe1,      tval_pe1)
        array.push(hist_tpe2,      tval_pe2)
        array.push(hist_tpe3,      tval_pe3)
        array.push(hist_tpe4,      tval_pe4)
        array.push(hist_tpe5,      tval_pe5)
        while array.size(hist_poc) > n_hist
            array.shift(hist_start_bar)
            array.shift(hist_end_bar)
            array.shift(hist_poc)
            array.shift(hist_hr_ce)
            array.shift(hist_hr_pe)
            array.shift(hist_tce1)
            array.shift(hist_tce2)
            array.shift(hist_tce3)
            array.shift(hist_tce4)
            array.shift(hist_tce5)
            array.shift(hist_tpe1)
            array.shift(hist_tpe2)
            array.shift(hist_tpe3)
            array.shift(hist_tpe4)
            array.shift(hist_tpe5)

    hr_upper_val    := na
    hr_lower_val    := na
    hr_ce_above_poc := false
    hr_pe_above_poc := false
    if not na(half_range) and half_range > 0
        _poc_ref = not na(prev_fib_poc) ? prev_fib_poc : fib_poc
        float _ref = not na(_poc_ref) ? _poc_ref : (ce_c + pe_c) / 2.0
        if ce_c > _ref
            hr_upper_val    := ce_c - half_range
            hr_ce_above_poc := true
        else
            hr_upper_val    := ce_c + half_range
            hr_ce_above_poc := false
        if pe_c > _ref
            hr_lower_val    := pe_c - half_range
            hr_pe_above_poc := true
        else
            hr_lower_val    := pe_c + half_range
            hr_pe_above_poc := false

    tval_ce1 := na
    tval_ce2 := na
    tval_ce3 := na
    tval_ce4 := na
    tval_ce5 := na
    tval_pe1 := na
    tval_pe2 := na
    tval_pe3 := na
    tval_pe4 := na
    tval_pe5 := na
    if not na(hr_upper_val) and not na(half_range)
        float _tv = half_range / 2.0
        tval_ce1 := hr_upper_val - _tv
        tval_ce2 := hr_upper_val + _tv
        tval_ce3 := hr_upper_val + half_range
        tval_ce4 := hr_upper_val + half_range * 1.5
        tval_ce5 := hr_upper_val + half_range * 2.0
    if not na(hr_lower_val) and not na(half_range)
        float _tv = half_range / 2.0
        tval_pe1 := hr_lower_val - _tv
        tval_pe2 := hr_lower_val + _tv
        tval_pe3 := hr_lower_val + half_range
        tval_pe4 := hr_lower_val + half_range * 1.5
        tval_pe5 := hr_lower_val + half_range * 2.0

// ═══════════════════════════════════════════════════════════
// 8B. BEP
// ═══════════════════════════════════════════════════════════
bep = (ce_d_c + pe_d_c) / 2.0

// ═══════════════════════════════════════════════════════════
// 8B2. STRADDLE
// ═══════════════════════════════════════════════════════════
straddle_close = ce_c + pe_c

var float straddle_entry     = na
var int   straddle_entry_bar = na
if is_new_session
    straddle_entry     := na
    straddle_entry_bar := na

straddle_is_entry_time = f_close_at_or_after(straddle_entry_hh, straddle_entry_mm)
if straddle_is_entry_time and na(straddle_entry)
    straddle_entry     := straddle_close
    straddle_entry_bar := bar_index

straddle_pnl_pct = not na(straddle_entry) and straddle_entry != 0 ?
     (straddle_direction == "Short (Credit)" ?
         (straddle_entry - straddle_close) / straddle_entry * 100.0 :
         (straddle_close - straddle_entry) / straddle_entry * 100.0) : na

float straddle_sl_val = na
if not na(straddle_entry)
    straddle_sl_val := straddle_direction == "Short (Credit)" ?
         straddle_entry * (1 + pct_straddle_sl / 100.0) :
         straddle_entry * (1 - pct_straddle_sl / 100.0)

straddle_sl_cross = not na(straddle_sl_val) and (straddle_direction == "Short (Credit)" ? ta.crossover(straddle_close, straddle_sl_val) : ta.crossunder(straddle_close, straddle_sl_val))
straddle_sl_hit   = show_straddle and straddle_sl_cross
straddle_is_exit_time = f_close_at_or_after(straddle_exit_hh, straddle_exit_mm)

// ═══════════════════════════════════════════════════════════
// 8B3. LONG STRADDLE @ 9:30
// ═══════════════════════════════════════════════════════════
ls_is_930 = f_close_at_or_after(ls_entry_hh, ls_entry_mm)

var float ls930_ce_entry = na
var float ls930_pe_entry = na
var float ls930_entry    = na
var float ls930_sl       = na
if is_new_session
    ls930_ce_entry := na
    ls930_pe_entry := na
    ls930_entry    := na
    ls930_sl       := na

if ls_is_930 and na(ls930_entry)
    ls930_ce_entry := ce_c
    ls930_pe_entry := pe_c
    ls930_entry    := ce_c + pe_c
    ls930_sl       := ls930_entry * (1 - pct_ls_sl / 100.0)

ls930_pnl_pct     = not na(ls930_entry) and ls930_entry != 0 ? (straddle_close - ls930_entry) / ls930_entry * 100.0 : na
ls930_cross_under = ta.crossunder(straddle_close, nz(ls930_sl, 0.0))
ls930_sl_hit      = not na(ls930_sl) and ls930_cross_under

// ═══════════════════════════════════════════════════════════
// 8C. VWAP
// ═══════════════════════════════════════════════════════════
var float ce_cum_tpv = 0.0
var float ce_cum_vol = 0.0
if is_new_session
    ce_cum_tpv := 0.0
    ce_cum_vol := 0.0
ce_tp       = (ce_h + ce_l + ce_c) / 3.0
ce_cum_tpv := ce_cum_tpv + ce_tp * nz(ce_vol)
ce_cum_vol := ce_cum_vol + nz(ce_vol)
ce_vwap     = ce_cum_vol > 0 ? ce_cum_tpv / ce_cum_vol : na

var float pe_cum_tpv = 0.0
var float pe_cum_vol = 0.0
if is_new_session
    pe_cum_tpv := 0.0
    pe_cum_vol := 0.0
pe_tp       = (pe_h + pe_l + pe_c) / 3.0
pe_cum_tpv := pe_cum_tpv + pe_tp * nz(pe_vol)
pe_cum_vol := pe_cum_vol + nz(pe_vol)
pe_vwap     = pe_cum_vol > 0 ? pe_cum_tpv / pe_cum_vol : na
pe_vwap_adj = pe_vwap - gap_offset

// ═══════════════════════════════════════════════════════════
// 8C2. OPTION SELLING STRATEGY
// ═══════════════════════════════════════════════════════════
os_is_exit_time = f_close_at_or_after(os_exit_hh, os_exit_mm)

var bool  os_ce_active = false
var bool  os_pe_active = false
var float os_ce_entry  = na
var float os_pe_entry  = na
var float os_ce_target = na
var float os_pe_target = na
var float os_ce_sl     = na
var float os_pe_sl     = na
var int   os_ce_entry_bar = na
var int   os_pe_entry_bar = na

// -- Snapshot HR levels at the time of sell entry so they don't change --
var float os_ce_hr_snap = na
var float os_pe_hr_snap = na
// -- Snapshot TV1 levels at sell entry time --
var float os_ce_tv1_snap = na
var float os_pe_tv1_snap = na

if is_new_session
    os_ce_active   := false
    os_pe_active   := false
    os_ce_entry    := na
    os_pe_entry    := na
    os_ce_target   := na
    os_pe_target   := na
    os_ce_sl       := na
    os_pe_sl       := na
    os_ce_entry_bar := na
    os_pe_entry_bar := na
    os_ce_hr_snap  := na
    os_pe_hr_snap  := na
    os_ce_tv1_snap := na
    os_pe_tv1_snap := na

signal_time_ok = f_close_at_or_after(os_entry_hh, os_entry_mm)

// -- Sell condition: opening candle close < open and below the opening POC. --
// -- Entry is the first confirmed bar close at/after the configured time. --
os_ce_sell_armed = not na(ce_open_close) and not na(ce_open_open) and not na(fib_poc) and ce_open_close < ce_open_open and ce_open_close < fib_poc
os_pe_sell_armed = not na(pe_open_close) and not na(pe_open_open) and not na(fib_poc) and pe_open_close < pe_open_open and pe_open_close < fib_poc

os_ce_entry_trigger = barstate.isconfirmed and show_os and signal_time_ok and na(os_ce_entry) and os_ce_sell_armed
if os_ce_entry_trigger
    os_ce_active   := true
    os_ce_entry    := ce_c
    os_ce_target   := ce_c * (1 - pct_os_target / 100.0)
    os_ce_sl       := hr_upper_val   // CE SL = CE HR level
    os_ce_hr_snap  := hr_upper_val   // snapshot CE HR at entry
    os_ce_tv1_snap := tval_ce1       // snapshot CE TV1 at entry (below CE HR)
    os_ce_entry_bar := bar_index

os_pe_entry_trigger = barstate.isconfirmed and show_os and signal_time_ok and na(os_pe_entry) and os_pe_sell_armed
if os_pe_entry_trigger
    os_pe_active   := true
    os_pe_entry    := pe_c
    os_pe_target   := pe_c * (1 - pct_os_target / 100.0)
    os_pe_sl       := hr_lower_val   // PE SL = PE HR level
    os_pe_hr_snap  := hr_lower_val   // snapshot PE HR at entry
    os_pe_tv1_snap := tval_pe1       // snapshot PE TV1 at entry (below PE HR)
    os_pe_entry_bar := bar_index

// -- CE Short exit conditions --
// The short opens at the entry bar close. If a later bar touches both target
// and stop, count the stop because OHLC data cannot establish target first.
os_ce_can_exit    = os_ce_active and not na(os_ce_entry_bar) and bar_index > os_ce_entry_bar
os_ce_sl_hit      = os_ce_can_exit and not na(os_ce_sl) and ce_h >= os_ce_sl
os_ce_target_hit  = os_ce_can_exit and not os_ce_sl_hit and not na(os_ce_target) and ce_l <= os_ce_target
os_ce_time_exit   = os_ce_can_exit and os_is_exit_time
os_ce_exit        = os_ce_target_hit or os_ce_sl_hit or os_ce_time_exit
os_ce_exit_reason = os_ce_sl_hit ? "SL(HR)" : os_ce_target_hit ? "Target" : os_ce_time_exit ? "Time" : ""

float os_ce_entry_snap  = os_ce_entry
float os_ce_target_snap = os_ce_target
float os_ce_sl_snap     = os_ce_sl

var string os_ce_exit_reason_persist = ""
if is_new_session
    os_ce_exit_reason_persist := ""
if os_ce_exit
    os_ce_active := false
    os_ce_exit_reason_persist := os_ce_exit_reason

// -- PE Short exit conditions --
os_pe_can_exit    = os_pe_active and not na(os_pe_entry_bar) and bar_index > os_pe_entry_bar
os_pe_sl_hit      = os_pe_can_exit and not na(os_pe_sl) and pe_h >= os_pe_sl
os_pe_target_hit  = os_pe_can_exit and not os_pe_sl_hit and not na(os_pe_target) and pe_l <= os_pe_target
os_pe_time_exit   = os_pe_can_exit and os_is_exit_time
os_pe_exit        = os_pe_target_hit or os_pe_sl_hit or os_pe_time_exit
os_pe_exit_reason = os_pe_sl_hit ? "SL(HR)" : os_pe_target_hit ? "Target" : os_pe_time_exit ? "Time" : ""

float os_pe_entry_snap  = os_pe_entry
float os_pe_target_snap = os_pe_target
float os_pe_sl_snap     = os_pe_sl

var string os_pe_exit_reason_persist = ""
if is_new_session
    os_pe_exit_reason_persist := ""
if os_pe_exit
    os_pe_active := false
    os_pe_exit_reason_persist := os_pe_exit_reason

// ═══════════════════════════════════════════════════════════
// 8C3. ADJUSTMENT SIGNAL (CORRECTED LOGIC)
// ─────────────────────────────────────────────────────────
// SELL PE active scenario:
//   Entry  : SELL PE at pe_entry with SL = PE HR level (hr_lower_val)
//   Levels : PE HR = hr_lower_val  (snapped at entry as os_pe_hr_snap)
//             PE TV1 = pe_tv1_snap = PE HR - (HR/2)   [BELOW PE HR]
//   Trigger: PE price rises AGAINST sell --> pe_h touches PE TV1 level
//             (PE TV1 is ABOVE PE HR since we SOLD, market moving up
//              means CE is cheaper -- BUY CE as hedge)
//
//   Wait -- TV1 formula: tval_pe1 = hr_lower_val - TV = hr_lower_val - HR/2
//   That is BELOW PE HR. When we SELL PE the risk is price going UP.
//   If PE price rises to PE HR that is our SL.
//   The adjustment trigger should be BEFORE the SL is hit:
//   i.e., when PE price rises from entry toward PE HR and crosses PE HR
//   the SL exits. Adjustment at PE TV1 means PE has risen to PE HR - TV
//   i.e., ABOVE entry (since entry is below PE HR for a short).
//   Correction: TV1 = PE_HR - TV is still BELOW PE HR.
//   If selling PE, entry < PE HR (entry is the 9:19 close which < POC < PE HR).
//   Adjustment at TV1 means price has risen from entry up to PE_HR - TV.
//   This is a valid mid-way alert before the SL at PE HR.
//
// So the CORRECT logic for adjustment is:
//   ADJ for SELL PE: fire when pe_h >= os_pe_tv1_snap  (price rising toward SL)
//                    => BUY 1 lot CE to hedge, SL = PE HR (os_pe_hr_snap)
//   ADJ for SELL CE: fire when ce_h >= os_ce_tv1_snap  (price rising toward SL)
//                    => BUY 1 lot PE to hedge, SL = CE HR (os_ce_hr_snap)
//
// KEY FIX: use snapshotted HR and TV1 values from entry time.
//          Fire ONLY while the sell position is still active (not after SL/Target exit).
//          Fire only ONCE per session per leg.
// ═══════════════════════════════════════════════════════════

var bool  adj_ce_fired  = false   // CE hedge fired (when SELL PE active and PE rises to TV1)
var bool  adj_pe_fired  = false   // PE hedge fired (when SELL CE active and CE rises to TV1)
var float adj_ce_entry  = na
var float adj_pe_entry  = na
var float adj_ce_sl     = na      // SL for the BUY CE hedge = PE HR
var float adj_pe_sl     = na      // SL for the BUY PE hedge = CE HR

if is_new_session
    adj_ce_fired := false
    adj_pe_fired := false
    adj_ce_entry := na
    adj_pe_entry := na
    adj_ce_sl    := na
    adj_pe_sl    := na

// ADJ CE: SELL PE is active AND PE price rises up to PE TV1 level (snapped at entry)
// os_pe_tv1_snap = pe_hr_snap - (HR/2) which is between entry and PE HR
// This fires ONLY while os_pe_active is true (position still open, SL not yet hit)
adj_ce_trigger = barstate.isconfirmed and os_pe_active and not na(os_pe_entry_bar) and bar_index > os_pe_entry_bar and not adj_ce_fired and not na(os_pe_tv1_snap) and pe_h >= os_pe_tv1_snap
if adj_ce_trigger
    adj_ce_fired := true
    adj_ce_entry := ce_c
    adj_ce_sl    := os_pe_hr_snap   // hedge SL = PE HR level (where PE sell SL is)

// ADJ PE: SELL CE is active AND CE price rises up to CE TV1 level (snapped at entry)
// os_ce_tv1_snap = ce_hr_snap - (HR/2) which is between entry and CE HR
// This fires ONLY while os_ce_active is true (position still open, SL not yet hit)
adj_pe_trigger = barstate.isconfirmed and os_ce_active and not na(os_ce_entry_bar) and bar_index > os_ce_entry_bar and not adj_pe_fired and not na(os_ce_tv1_snap) and ce_h >= os_ce_tv1_snap
if adj_pe_trigger
    adj_pe_fired := true
    adj_pe_entry := pe_c
    adj_pe_sl    := os_ce_hr_snap   // hedge SL = CE HR level (where CE sell SL is)

// ═══════════════════════════════════════════════════════════
// 8D. TRADE SETTINGS + ALERT FILTER
// ═══════════════════════════════════════════════════════════
grp_trade       = "Trade Signals"
show_trade      = input.bool(true, title="Show Trade Signals", group=grp_trade)
enable_alerts   = input.bool(true, title="Enable Alerts",      group=grp_trade)
one_buy_trade_per_leg_per_day = input.bool(true, title="Limit to One CE/PE Buy Trade Per Day", group=grp_trade,
                              tooltip="ON: each leg can enter only once per session. OFF: a leg may re-enter after its prior trade exits, subject to all other filters and the forced-exit time.")
alert_freq_once = input.bool(true, title="Alert Once Per Bar (uncheck = every tick)", group=grp_trade,
                  tooltip="ON: alert fires once when the bar closes. OFF: fires on every realtime tick.")

// -- Alert type filter for webhook --
grp_alert_filter = "Alert Filter (Webhook)"
alert_mode = input.string("Both Buy and Sell",
             options=["Buy Trades Only", "Sell Trades Only", "Both Buy and Sell"],
             title="Send Alerts For", group=grp_alert_filter,
             tooltip="Buy Trades Only  : CE/PE long buy entries and exits only.\nSell Trades Only : CE/PE short sell entries, exits, and adjustments only.\nBoth Buy and Sell: all trade alerts.")

force_exit_hh   = input.int(15, title="Force Exit Hour",   group=grp_trade, minval=0, maxval=23, inline="texit")
force_exit_mm   = input.int(15, title="Force Exit Minute", group=grp_trade, minval=0, maxval=59, inline="texit",
                  tooltip="Any open CE/PE Buy trade is force-closed at this time.")

_alert_freq = alert_freq_once ? alert.freq_once_per_bar : alert.freq_all

// -- Alert gate helpers --
_allow_buy  = alert_mode == "Buy Trades Only"  or alert_mode == "Both Buy and Sell"
_allow_sell = alert_mode == "Sell Trades Only" or alert_mode == "Both Buy and Sell"

// ═══════════════════════════════════════════════════════════
// 8E. SPOT DATA + SPOT ORB
// ═══════════════════════════════════════════════════════════
spot_sym   = input.symbol("NSE:NIFTY", title="Spot Symbol", group=grp_trade)

// Optional spot-market filters for CE/PE buying. They are OFF by default so
// existing signal behaviour is preserved until explicitly enabled.
grp_spot_filter          = "Spot Trend Filters"
use_spot_supertrend      = input.bool(false, title="Use Spot Supertrend Filter", group=grp_spot_filter)
spot_st_atr_length       = input.int(10, title="Supertrend ATR Length", minval=1, group=grp_spot_filter, inline="st")
spot_st_factor           = input.float(2.0, title="Factor", minval=0.1, step=0.1, group=grp_spot_filter, inline="st")
use_spot_vwap_direction  = input.bool(false, title="Use Spot VWAP Direction Filter", group=grp_spot_filter)
spot_vwap_slope_bars     = input.int(1, title="VWAP Slope Lookback Bars", minval=1, group=grp_spot_filter,
                            tooltip="CE needs spot above a rising VWAP; PE needs spot below a falling VWAP.")
use_spot_adx_filter      = input.bool(false, title="Use Spot ADX Strength Filter", group=grp_spot_filter, inline="adx")
spot_adx_length          = input.int(14, title="ADX Length", minval=1, group=grp_spot_filter, inline="adx")
spot_adx_threshold       = input.float(20.0, title="Threshold", minval=1.0, step=0.5, group=grp_spot_filter, inline="adx")
use_spot_adx_di_filter   = input.bool(false, title="Use +DI/-DI Direction Filter", group=grp_spot_filter,
                            tooltip="When ON: CE requires +DI > -DI and PE requires -DI > +DI.")

spot_close = request.security(spot_sym, timeframe.period, close)
spot_high  = request.security(spot_sym, timeframe.period, high)
spot_low   = request.security(spot_sym, timeframe.period, low)
spot_vol   = request.security(spot_sym, timeframe.period, volume)
[spot_supertrend, spot_supertrend_dir] = request.security(spot_sym, timeframe.period, ta.supertrend(spot_st_factor, spot_st_atr_length))
[spot_adx, spot_di_plus, spot_di_minus] = request.security(spot_sym, timeframe.period,
    [ta.adx(spot_adx_length), ta.plusdi(spot_adx_length), ta.minusdi(spot_adx_length)])

var float spot_orb_high = na
var float spot_orb_low  = na
if is_new_session
    spot_orb_high := spot_high
    spot_orb_low  := spot_low

spot_oc_mid = (not na(spot_orb_high) and not na(spot_orb_low)) ? (spot_orb_high + spot_orb_low) / 2.0 : na

var float spot_cum_tpv = 0.0
var float spot_cum_vol = 0.0
if is_new_session
    spot_cum_tpv := 0.0
    spot_cum_vol := 0.0
spot_tp       = (spot_high + spot_low + spot_close) / 3.0
spot_cum_tpv := spot_cum_tpv + spot_tp * nz(spot_vol)
spot_cum_vol := spot_cum_vol + nz(spot_vol)
spot_vwap     = spot_cum_vol > 0 ? spot_cum_tpv / spot_cum_vol : na

// ta.supertrend() returns a negative direction for an uptrend and a positive
// direction for a downtrend. Calculate it in request.security so its ATR uses
// NIFTY spot OHLC, never the chart or option OHLC.
spot_st_bull = not na(spot_supertrend) and spot_supertrend_dir < 0
spot_st_bear = not na(spot_supertrend) and spot_supertrend_dir > 0
spot_vwap_up = not na(spot_vwap) and not na(spot_vwap[spot_vwap_slope_bars]) and spot_close > spot_vwap and spot_vwap > spot_vwap[spot_vwap_slope_bars]
spot_vwap_down = not na(spot_vwap) and not na(spot_vwap[spot_vwap_slope_bars]) and spot_close < spot_vwap and spot_vwap < spot_vwap[spot_vwap_slope_bars]

spot_adx_strength_ok = not use_spot_adx_filter or (not na(spot_adx) and spot_adx >= spot_adx_threshold)
spot_ce_di_ok        = not use_spot_adx_di_filter or (not na(spot_di_plus) and not na(spot_di_minus) and spot_di_plus > spot_di_minus)
spot_pe_di_ok        = not use_spot_adx_di_filter or (not na(spot_di_plus) and not na(spot_di_minus) and spot_di_minus > spot_di_plus)

spot_ce_trend_ok = (not use_spot_supertrend or spot_st_bull) and (not use_spot_vwap_direction or spot_vwap_up) and spot_adx_strength_ok and spot_ce_di_ok
spot_pe_trend_ok = (not use_spot_supertrend or spot_st_bear) and (not use_spot_vwap_direction or spot_vwap_down) and spot_adx_strength_ok and spot_pe_di_ok

// ═══════════════════════════════════════════════════════════
// 8F. SIGNAL LOGIC (BUY side)
// ═══════════════════════════════════════════════════════════
ce_base_long = not na(ce_c) and ce_c > 0 and not na(ce_vwap) and not na(hr_lower_val) and ce_c > ce_vwap and ce_c > hr_lower_val
pe_base_long = not na(pe_c) and pe_c > 0 and not na(pe_vwap) and not na(hr_upper_val) and pe_c > pe_vwap and pe_c > hr_upper_val
long_ce = ce_base_long and spot_ce_trend_ok
long_pe = pe_base_long and spot_pe_trend_ok

// ═══════════════════════════════════════════════════════════
// 8G. TRADE STATE TRACKING (BUY side)
// ═══════════════════════════════════════════════════════════
var bool  in_ce_trade     = false
var float ce_entry_prem   = na
var float ce_target1_prem = na
var float ce_target2_prem = na
var bool  ce_t1_done      = false
var float ce_sl_prem_lvl  = na
var bool  ce_trade_done   = false
var int   ce_entry_bar    = na

var bool  in_pe_trade     = false
var float pe_entry_prem   = na
var float pe_target1_prem = na
var float pe_target2_prem = na
var bool  pe_t1_done      = false
var float pe_sl_prem_lvl  = na
var bool  pe_trade_done   = false
var int   pe_entry_bar    = na

if is_new_session
    ce_trade_done   := false
    pe_trade_done   := false
    in_ce_trade     := false
    ce_entry_prem   := na
    ce_target1_prem := na
    ce_target2_prem := na
    ce_t1_done      := false
    ce_sl_prem_lvl  := na
    ce_entry_bar    := na
    in_pe_trade     := false
    pe_entry_prem   := na
    pe_target1_prem := na
    pe_target2_prem := na
    pe_t1_done      := false
    pe_sl_prem_lvl  := na
    pe_entry_bar    := na

trade_is_force_exit_time = f_close_at_or_after(force_exit_hh, force_exit_mm)
buy_entry_time_ok = buy_time_ok and not trade_is_force_exit_time

var float ce_hr_at_entry = na
if is_new_session
    ce_hr_at_entry := na

var float ce_entry_snap  = na
var float ce_t1_snap     = na
var float ce_t2_snap     = na
var float ce_sl_snap     = na
var float ce_hr_snap     = na
if is_new_session
    ce_entry_snap := na
    ce_t1_snap    := na
    ce_t2_snap    := na
    ce_sl_snap    := na
    ce_hr_snap    := na

// Block BUY CE if SELL CE is already active (cannot be long and short same leg)
// NEW: buy_time_ok = bar must CLOSE at/after 9:30 (first eligible trigger 9:30)
ce_signal_trigger = barstate.isconfirmed and long_ce and not in_ce_trade and (not one_buy_trade_per_leg_per_day or not ce_trade_done) and buy_entry_time_ok and not na(session_half_range) and not na(ce_c) and ce_c > 0 and not os_ce_active
if ce_signal_trigger
    in_ce_trade     := true
    ce_trade_done   := true
    ce_entry_prem   := ce_c
    ce_hr_at_entry  := session_half_range
    ce_target1_prem := ce_c + session_half_range / 2.0
    ce_target2_prem := ce_c + session_half_range
    ce_t1_done      := false
    ce_sl_prem_lvl  := ce_c - session_half_range
    ce_entry_snap   := ce_c
    ce_t1_snap      := ce_c + session_half_range / 2.0
    ce_t2_snap      := ce_c + session_half_range
    ce_sl_snap      := ce_c - session_half_range
    ce_hr_snap      := session_half_range
    ce_entry_bar    := bar_index

ce_can_exit = in_ce_trade and not na(ce_entry_bar) and bar_index > ce_entry_bar
ce_sl_hit    = barstate.isconfirmed and ce_can_exit and not na(ce_sl_prem_lvl) and ce_l <= ce_sl_prem_lvl
ce_t1_hit = ce_can_exit and not ce_sl_hit and not ce_t1_done and not na(ce_target1_prem) and ce_h >= ce_target1_prem
if ce_t1_hit
    ce_t1_done := true

ce_t2_hit    = ce_can_exit and not ce_sl_hit and not na(ce_target2_prem) and ce_h >= ce_target2_prem
ce_time_exit = ce_can_exit and trade_is_force_exit_time
ce_exit      = ce_t2_hit or ce_sl_hit or ce_time_exit

ce_exit_entry_prem = ce_entry_prem
ce_exit_sl_prem    = ce_sl_prem_lvl
ce_exit_t1_prem    = ce_target1_prem
ce_exit_t2_prem    = ce_target2_prem

if ce_exit
    in_ce_trade     := false
    ce_entry_prem   := na
    ce_target1_prem := na
    ce_target2_prem := na
    ce_t1_done      := false
    ce_sl_prem_lvl  := na
    ce_hr_at_entry  := na
    ce_entry_bar    := na

var float pe_hr_at_entry = na
if is_new_session
    pe_hr_at_entry := na

var float pe_entry_snap  = na
var float pe_t1_snap     = na
var float pe_t2_snap     = na
var float pe_sl_snap     = na
var float pe_hr_snap     = na
if is_new_session
    pe_entry_snap := na
    pe_t1_snap    := na
    pe_t2_snap    := na
    pe_sl_snap    := na
    pe_hr_snap    := na

// Block BUY PE if SELL PE is already active (cannot be long and short same leg)
// NEW: buy_time_ok = bar must CLOSE at/after 9:30 (first eligible trigger 9:30)
pe_signal_trigger = barstate.isconfirmed and long_pe and not in_pe_trade and (not one_buy_trade_per_leg_per_day or not pe_trade_done) and buy_entry_time_ok and not na(session_half_range) and not na(pe_c) and pe_c > 0 and not os_pe_active
if pe_signal_trigger
    in_pe_trade     := true
    pe_trade_done   := true
    pe_entry_prem   := pe_c
    pe_hr_at_entry  := session_half_range
    pe_target1_prem := pe_c + session_half_range / 2.0
    pe_target2_prem := pe_c + session_half_range
    pe_t1_done      := false
    pe_sl_prem_lvl  := pe_c - session_half_range
    pe_entry_snap   := pe_c
    pe_t1_snap      := pe_c + session_half_range / 2.0
    pe_t2_snap      := pe_c + session_half_range
    pe_sl_snap      := pe_c - session_half_range
    pe_hr_snap      := session_half_range
    pe_entry_bar    := bar_index

pe_can_exit = in_pe_trade and not na(pe_entry_bar) and bar_index > pe_entry_bar
pe_sl_hit    = barstate.isconfirmed and pe_can_exit and not na(pe_sl_prem_lvl) and pe_l <= pe_sl_prem_lvl
pe_t1_hit = pe_can_exit and not pe_sl_hit and not pe_t1_done and not na(pe_target1_prem) and pe_h >= pe_target1_prem
if pe_t1_hit
    pe_t1_done := true

pe_t2_hit    = pe_can_exit and not pe_sl_hit and not na(pe_target2_prem) and pe_h >= pe_target2_prem
pe_time_exit = pe_can_exit and trade_is_force_exit_time
pe_exit      = pe_t2_hit or pe_sl_hit or pe_time_exit

pe_exit_entry_prem = pe_entry_prem
pe_exit_sl_prem    = pe_sl_prem_lvl
pe_exit_t1_prem    = pe_target1_prem
pe_exit_t2_prem    = pe_target2_prem

if pe_exit
    in_pe_trade     := false
    pe_entry_prem   := na
    pe_target1_prem := na
    pe_target2_prem := na
    pe_t1_done      := false
    pe_sl_prem_lvl  := na
    pe_entry_bar    := na

