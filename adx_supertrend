var float hr_lower_val    = na
var bool  hr_ce_above_poc = false
var bool  hr_pe_above_poc = false

var float tval_ce1 = na
var float tval_ce2 = na
var float tval_ce3 = na
var float tval_ce4 = na
var float tval_ce5 = na
var float tval_pe1 = na
var float tval_pe2 = na
var float tval_pe3 = na
var float tval_pe4 = na
var float tval_pe5 = na

