        label.delete(lb_pe_t1)

// -- PE Target 2 --
var line  ln_pe_t2 = na
var label lb_pe_t2 = na
if barstate.islast
    if show_all_pe and show_pe_t2 and not na(session_start_bar) and not na(pe_open_high) and not na(pe_open_low)
        line.delete(ln_pe_t2)
        label.delete(lb_pe_t2)
        ln_pe_t2 := line.new(session_start_bar, pe_t2_val - gap_offset, bar_index + 5, pe_t2_val - gap_offset, color=col_pe_t2, width=wid_pe_t2, style=f_ls(sty_pe_t2))
        lb_pe_t2 := label.new(bar_index + 5, pe_t2_val - gap_offset, "PE T2(" + str.tostring(pct_pe_t2, "#") + "%): " + str.tostring(pe_t2_val, "#.##"), color=col_pe_t2, textcolor=color.black, style=label.style_label_left, size=size.small)
    else
        line.delete(ln_pe_t2)
        label.delete(lb_pe_t2)

// ═══════════════════════════════════════════════════════════
// 11. DASHBOARD
// ═══════════════════════════════════════════════════════════
col_act     = color.new(color.green,  0)
col_wait    = color.new(#333333,     30)
col_hdr     = color.new(#1a1a2e,      0)
col_ref     = color.new(#1e1e2e,     10)
col_bep_row = color.new(#444444,     40)
txt_white   = color.white
txt_black   = color.black
txt_dim     = color.new(color.white, 40)

fmt2(v) => na(v) ? "n/a" : str.tostring(v, "#.00")
pad2(v) => v < 10 ? "0" + str.tostring(v) : str.tostring(v)

f_pos(p) =>
    var _r = position.bottom_left
    if p == "Top Left"
        _r := position.top_left
    else if p == "Top Right"
        _r := position.top_right
    else if p == "Bottom Right"
        _r := position.bottom_right
    _r

var table dash = na

if show_dashboard and not mobile_mode
    if na(dash)
        dash := table.new(f_pos(dash_pos), columns=2, rows=30,
                 bgcolor=color.new(#0a0a14, 5),
                 border_color=color.new(color.gray, 60),
                 border_width=1)

    table.cell(dash, 0, 0, "CE & PE  Dashboard", bgcolor=col_hdr, text_color=txt_white, text_halign=text.align_center, text_size=size.normal)
    table.cell(dash, 1, 0, "", bgcolor=col_hdr)
    table.merge_cells(dash, 0, 0, 1, 0)

    table.cell(dash, 0, 1, "  Signal", bgcolor=color.new(#111133, 0), text_color=txt_dim, text_size=size.small)
    table.cell(dash, 1, 1, "Value / Status", bgcolor=color.new(#111133, 0), text_color=txt_dim, text_size=size.small, text_halign=text.align_center)

    ce_above_vwap = not na(ce_vwap) and ce_c > ce_vwap
    ce_above_hr   = not na(hr_lower_val) and ce_c > hr_lower_val
    ce_sig_txt = long_ce ? "** LONG CE **" :
         (not ce_above_vwap ? "WAIT: below VWAP" :
         (not ce_above_hr   ? "WAIT: below PE HR(" + str.tostring(hr_lower_val,"#.0") + ")" :
         (not spot_ce_trend_ok ? "WAIT: spot trend" : "WAIT: gating")))
    ce_sig_bg  = long_ce ? col_act : col_wait
    table.cell(dash, 0, 2, "Long CE", bgcolor=ce_sig_bg, text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 2, ce_sig_txt, bgcolor=ce_sig_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    pe_above_vwap = not na(pe_vwap) and pe_c > pe_vwap
    pe_above_hr   = not na(hr_upper_val) and pe_c > hr_upper_val
    pe_sig_txt = long_pe ? "** LONG PE **" :
         (not pe_above_vwap ? "WAIT: below VWAP" :
         (not pe_above_hr   ? "WAIT: below CE HR(" + str.tostring(hr_upper_val,"#.0") + ")" :
         (not spot_pe_trend_ok ? "WAIT: spot trend" : "WAIT: gating")))
    pe_sig_bg  = long_pe ? col_act : col_wait
    table.cell(dash, 0, 3, "Long PE", bgcolor=pe_sig_bg, text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 3, pe_sig_txt, bgcolor=pe_sig_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 4, "-- VWAP Values --", bgcolor=color.new(#222244, 0), text_color=txt_dim, text_halign=text.align_center, text_size=size.small)
    table.cell(dash, 1, 4, "", bgcolor=color.new(#222244, 0))
    table.merge_cells(dash, 0, 4, 1, 4)

    ce_vwap_str = fmt2(ce_vwap)
    ce_vs_vwap  = not na(ce_vwap) and ce_c > ce_vwap ? " [above]" : " [below]"
    table.cell(dash, 0, 5, "CE VWAP", bgcolor=color.new(#00FFFF, 80), text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 5, ce_vwap_str + ce_vs_vwap, bgcolor=color.new(#00FFFF, 80), text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    pe_vwap_str = fmt2(pe_vwap)
    pe_vs_vwap  = not na(pe_vwap) and pe_c > pe_vwap ? " [above]" : " [below]"
    table.cell(dash, 0, 6, "PE VWAP", bgcolor=color.new(#FF00FF, 80), text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 6, pe_vwap_str + pe_vs_vwap, bgcolor=color.new(#FF00FF, 80), text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 7, "BEP (Prev Close Avg)", bgcolor=col_bep_row, text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 7, fmt2(bep), bgcolor=col_bep_row, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 8, "-- Reference Levels --", bgcolor=color.new(#222244, 0), text_color=txt_dim, text_halign=text.align_center, text_size=size.small)
    table.cell(dash, 1, 8, "", bgcolor=color.new(#222244, 0))
    table.merge_cells(dash, 0, 8, 1, 8)

    table.cell(dash, 0, 9, "POC", bgcolor=col_ref, text_color=color.yellow, text_size=size.small)
    table.cell(dash, 1, 9, fmt2(fib_poc), bgcolor=col_ref, text_color=color.yellow, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 10, "Half Range (CE/PE Close)", bgcolor=color.new(#1a1a00, 30), text_color=color.new(color.white, 20), text_size=size.small)
    table.cell(dash, 1, 10, str.tostring(half_range, "#.0") + " pts", bgcolor=color.new(#1a1a00, 30), text_color=color.new(color.white, 20), text_size=size.small, text_halign=text.align_center)

    hr_upper_str = not na(hr_upper_val) ? fmt2(hr_upper_val) + (hr_ce_above_poc ? " [>POC -HR]" : " [<POC +HR]") : "n/a"
    table.cell(dash, 0, 11, "HR CE Level", bgcolor=color.new(#003322, 0), text_color=col_hr_upper, text_size=size.small)
    table.cell(dash, 1, 11, hr_upper_str, bgcolor=color.new(#003322, 0), text_color=col_hr_upper, text_size=size.small, text_halign=text.align_center)

    hr_lower_str = not na(hr_lower_val) ? fmt2(hr_lower_val) + (hr_pe_above_poc ? " [>POC -HR]" : " [<POC +HR]") : "n/a"
    table.cell(dash, 0, 12, "HR PE Level", bgcolor=color.new(#330000, 0), text_color=col_hr_lower, text_size=size.small)
    table.cell(dash, 1, 12, hr_lower_str, bgcolor=color.new(#330000, 0), text_color=col_hr_lower, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 13, "-- Active Trade --", bgcolor=color.new(#1a1a00, 0), text_color=color.new(color.yellow, 0), text_halign=text.align_center, text_size=size.small)
    table.cell(dash, 1, 13, "", bgcolor=color.new(#1a1a00, 0))
    table.merge_cells(dash, 0, 13, 1, 13)

    ce_trade_txt = in_ce_trade ? "IN TRADE" : (ce_trade_done ? "Done for Day" : "No Trade")
    ce_trade_bg  = in_ce_trade ? color.new(color.green, 20) : color.new(#222222, 0)
    ce_trade_val = in_ce_trade ?
         "E:" + str.tostring(ce_entry_prem, "#.0") +
         " T1:" + str.tostring(ce_target1_prem, "#.0") + (ce_t1_done ? "[x]" : "") +
         " T2:" + str.tostring(ce_target2_prem, "#.0") +
         " SL:" + str.tostring(ce_sl_prem_lvl, "#.0") : "--"
    table.cell(dash, 0, 14, "CE " + ce_trade_txt, bgcolor=ce_trade_bg, text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 14, ce_trade_val, bgcolor=ce_trade_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    pe_trade_txt = in_pe_trade ? "IN TRADE" : (pe_trade_done ? "Done for Day" : "No Trade")
    pe_trade_bg  = in_pe_trade ? color.new(color.red, 20) : color.new(#222222, 0)
    pe_trade_val = in_pe_trade ?
         "E:" + str.tostring(pe_entry_prem, "#.0") +
         " T1:" + str.tostring(pe_target1_prem, "#.0") + (pe_t1_done ? "[x]" : "") +
         " T2:" + str.tostring(pe_target2_prem, "#.0") +
         " SL:" + str.tostring(pe_sl_prem_lvl, "#.0") : "--"
    table.cell(dash, 0, 15, "PE " + pe_trade_txt, bgcolor=pe_trade_bg, text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 15, pe_trade_val, bgcolor=pe_trade_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    spot_vs_vwap = not na(spot_close) and not na(spot_vwap) ? (spot_close > spot_vwap ? " [above]" : " [below]") : ""
    table.cell(dash, 0, 16, "Spot VWAP", bgcolor=color.new(#111111, 0), text_color=txt_dim, text_size=size.small)
    table.cell(dash, 1, 16, fmt2(spot_vwap) + spot_vs_vwap, bgcolor=color.new(#111111, 0), text_color=color.white, text_size=size.small, text_halign=text.align_center)

    spot_vs_mid = not na(spot_close) and not na(spot_oc_mid) ? (spot_close > spot_oc_mid ? " [above]" : " [below]") : ""
    table.cell(dash, 0, 17, "Spot ORB Mid", bgcolor=color.new(#111111, 0), text_color=txt_dim, text_size=size.small)
    table.cell(dash, 1, 17, fmt2(spot_oc_mid) + spot_vs_mid, bgcolor=color.new(#111111, 0), text_color=color.white, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 18, "Spot Now", bgcolor=color.new(#111111, 0), text_color=txt_dim, text_size=size.small)
    table.cell(dash, 1, 18, fmt2(spot_close), bgcolor=color.new(#111111, 0), text_color=color.white, text_size=size.small, text_halign=text.align_center)

    straddle_entry_lbl = "Straddle @ " + pad2(straddle_entry_hh) + ":" + pad2(straddle_entry_mm)
    table.cell(dash, 0, 19, straddle_entry_lbl, bgcolor=color.new(#444400, 30), text_color=color.yellow, text_size=size.small)
    table.cell(dash, 1, 19, fmt2(straddle_entry), bgcolor=color.new(#444400, 30), text_color=color.yellow, text_size=size.small, text_halign=text.align_center)

    straddle_pnl_str = na(straddle_pnl_pct) ? "n/a" : str.tostring(straddle_pnl_pct, "#.00") + "%"
    straddle_pnl_bg  = na(straddle_pnl_pct) ? color.new(#222222, 0) : (straddle_pnl_pct >= 0 ? color.new(color.green, 60) : color.new(color.red, 60))
    table.cell(dash, 0, 20, "Straddle P&L %", bgcolor=straddle_pnl_bg, text_color=txt_white, text_size=size.small)
    table.cell(dash, 1, 20, straddle_pnl_str, bgcolor=straddle_pnl_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 21, "Straddle SL", bgcolor=color.new(color.red, 70), text_color=col_straddle_sl, text_size=size.small)
    table.cell(dash, 1, 21, fmt2(straddle_sl_val), bgcolor=color.new(color.red, 70), text_color=col_straddle_sl, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 22, "-- Option Selling --", bgcolor=color.new(#222244, 0), text_color=txt_dim, text_halign=text.align_center, text_size=size.small)
    table.cell(dash, 1, 22, "", bgcolor=color.new(#222244, 0))
    table.merge_cells(dash, 0, 22, 1, 22)

    os_ce_status = os_ce_active ? ("SHORT @" + str.tostring(os_ce_entry, "#.0") + " Tgt:" + str.tostring(os_ce_target, "#.0") + " SL(HR):" + str.tostring(os_ce_sl, "#.0")) : (na(os_ce_entry) ? "No Position" : "Closed (" + os_ce_exit_reason_persist + ")")
    os_ce_bg     = os_ce_active ? color.new(color.green, 60) : color.new(#222222, 0)
    table.cell(dash, 0, 23, "CE Short", bgcolor=os_ce_bg, text_color=col_os_ce, text_size=size.small)
    table.cell(dash, 1, 23, os_ce_status, bgcolor=os_ce_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    os_pe_status = os_pe_active ? ("SHORT @" + str.tostring(os_pe_entry, "#.0") + " Tgt:" + str.tostring(os_pe_target, "#.0") + " SL(HR):" + str.tostring(os_pe_sl, "#.0")) : (na(os_pe_entry) ? "No Position" : "Closed (" + os_pe_exit_reason_persist + ")")
    os_pe_bg     = os_pe_active ? color.new(color.red, 60) : color.new(#222222, 0)
    table.cell(dash, 0, 24, "PE Short", bgcolor=os_pe_bg, text_color=col_os_pe, text_size=size.small)
    table.cell(dash, 1, 24, os_pe_status, bgcolor=os_pe_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    table.cell(dash, 0, 25, "HR / TV pts", bgcolor=color.new(#0a0a20, 0), text_color=txt_dim, text_size=size.small)
    table.cell(dash, 1, 25, str.tostring(nz(session_half_range, half_range), "#.0") + " / " + str.tostring(nz(session_half_range, half_range) / 2.0, "#.0"), bgcolor=color.new(#0a0a20, 0), text_color=color.new(color.white, 30), text_size=size.small, text_halign=text.align_center)

    // -- Adjustment rows --
    table.cell(dash, 0, 26, "-- Adjustment --", bgcolor=color.new(#332200, 0), text_color=color.new(#FF6600, 0), text_halign=text.align_center, text_size=size.small)
    table.cell(dash, 1, 26, "", bgcolor=color.new(#332200, 0))
    table.merge_cells(dash, 0, 26, 1, 26)

    // ADJ CE row: SELL PE active, waiting for PE to rise to snapped PE TV1
    _adj_ce_tv1_disp = not na(os_pe_tv1_snap) ? str.tostring(os_pe_tv1_snap, "#.0") : str.tostring(tval_pe1, "#.0")
    adj_ce_status = adj_ce_fired ? ("BUY CE @" + str.tostring(adj_ce_entry, "#.0") + " SL(PE HR):" + str.tostring(adj_ce_sl, "#.0")) : (os_pe_active ? "PE rising to TV1=" + _adj_ce_tv1_disp : (not na(os_pe_entry) ? "Closed" : "--"))
    adj_ce_bg     = adj_ce_fired ? color.new(#FF6600, 40) : color.new(#222222, 0)
    table.cell(dash, 0, 27, "ADJ: BUY CE (SELL PE)", bgcolor=adj_ce_bg, text_color=color.new(#FF6600, 0), text_size=size.small)
    table.cell(dash, 1, 27, adj_ce_status, bgcolor=adj_ce_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    // ADJ PE row: SELL CE active, waiting for CE to rise to snapped CE TV1
    _adj_pe_tv1_disp = not na(os_ce_tv1_snap) ? str.tostring(os_ce_tv1_snap, "#.0") : str.tostring(tval_ce1, "#.0")
    adj_pe_status = adj_pe_fired ? ("BUY PE @" + str.tostring(adj_pe_entry, "#.0") + " SL(CE HR):" + str.tostring(adj_pe_sl, "#.0")) : (os_ce_active ? "CE rising to TV1=" + _adj_pe_tv1_disp : (not na(os_ce_entry) ? "Closed" : "--"))
    adj_pe_bg     = adj_pe_fired ? color.new(#FF6600, 40) : color.new(#222222, 0)
    table.cell(dash, 0, 28, "ADJ: BUY PE (SELL CE)", bgcolor=adj_pe_bg, text_color=color.new(#FF6600, 0), text_size=size.small)
    table.cell(dash, 1, 28, adj_pe_status, bgcolor=adj_pe_bg, text_color=txt_white, text_size=size.small, text_halign=text.align_center)

    // -- Alert mode row --
    table.cell(dash, 0, 29, "Alert Mode", bgcolor=color.new(#1a1a2e, 0), text_color=txt_dim, text_size=size.small)
    table.cell(dash, 1, 29, alert_mode, bgcolor=color.new(#1a1a2e, 0), text_color=color.yellow, text_size=size.small, text_halign=text.align_center)

else
    if not na(dash)
        table.delete(dash)
        dash := na

if mobile_mode and not na(dash)
    table.delete(dash)
    dash := na
